<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://tools.android.com/tools"
    package="com.example.nailzbynut">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Nailzbynut"
        tools:targetApi="31">

        <activity
            android:name=".SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".LoginActivity"
            android:exported="false" />
        <activity
            android:name=".SignUpActivity"
            android:exported="false" />

        <activity
            android:name=".MainNavigationActivity"
            android:exported="false" />

        <activity
            android:name=".ExploreActivity"
            android:exported="false" />
        <activity
            android:name=".WishlistActivity"
            android:exported="false" />
        <activity
            android:name=".ServicesActivity"
            android:exported="false" />
        <activity
            android:name=".HistoryActivity"
            android:exported="false" />
        <activity
            android:name=".ProfileFragment"
            android:exported="false" />

        <activity
            android:name=".BookingAppointmentActivity"
            android:exported="false" />

        <activity
            android:name=".CustomNailShapeActivity"
            android:exported="false" />

        <activity
            android:name=".CustomNailColorActivity"
            android:exported="false" />

        <activity
            android:name=".CustomNailDetailsActivity"
            android:exported="false" />

        <activity
            android:name=".CustomNailReviewActivity"
            android:exported="false" />

    </application>

</manifest>