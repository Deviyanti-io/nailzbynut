<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <RelativeLayout
        android:id="@+id/layout_top_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp">
        <ImageView
            android:id="@+id/btn_back_details"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_back"
            app:tint="@color/text_primary"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Custom Nail"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:fontFamily="@font/fredoka_bold"/>
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layout_top_bar"
        android:layout_above="@+id/btn_next_details"
        android:scrollbars="none"
        android:paddingHorizontal="20dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Stepper -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="24dp">
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_weight="1">
                    <TextView android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_circle_color" android:backgroundTint="@color/lavender_dark" android:text="✓" android:textColor="@color/white" android:gravity="center" android:fontFamily="@font/poppins_bold" android:textSize="12sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Shape" android:textColor="@color/lavender_dark" android:textSize="11sp" android:fontFamily="@font/poppins_medium" android:layout_marginTop="4dp"/>
                </LinearLayout>
                <View android:layout_width="35dp" android:layout_height="2dp" android:background="@color/lavender_dark" android:layout_marginBottom="14dp"/>
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_weight="1">
                    <TextView android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_circle_color" android:backgroundTint="@color/lavender_dark" android:text="✓" android:textColor="@color/white" android:gravity="center" android:fontFamily="@font/poppins_bold" android:textSize="12sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Color" android:textColor="@color/lavender_dark" android:textSize="11sp" android:fontFamily="@font/poppins_medium" android:layout_marginTop="4dp"/>
                </LinearLayout>
                <View android:layout_width="35dp" android:layout_height="2dp" android:background="@color/lavender_dark" android:layout_marginBottom="14dp"/>
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_weight="1">
                    <TextView android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_circle_color" android:backgroundTint="@color/lavender_dark" android:text="3" android:textColor="@color/white" android:gravity="center" android:fontFamily="@font/poppins_bold" android:textSize="12sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Details" android:textColor="@color/lavender_dark" android:textSize="11sp" android:fontFamily="@font/poppins_bold" android:layout_marginTop="4dp"/>
                </LinearLayout>
                <View android:layout_width="35dp" android:layout_height="2dp" android:background="@color/divider" android:layout_marginBottom="14dp"/>
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_weight="1">
                    <TextView android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_circle_color" android:backgroundTint="@color/divider" android:text="4" android:textColor="@color/text_secondary" android:gravity="center" android:fontFamily="@font/poppins_bold" android:textSize="12sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Review" android:textColor="@color/text_secondary" android:textSize="11sp" android:fontFamily="@font/poppins_medium" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Select Preset Size" android:textColor="@color/text_primary" android:textSize="15sp" android:fontFamily="@font/poppins_bold" android:layout_marginBottom="12dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="3" android:layout_marginBottom="24dp">
                <Button android:id="@+id/btn_size_s" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="Size S" android:textColor="@color/text_primary" android:backgroundTint="@color/background_card" android:textAllCaps="false" android:fontFamily="@font/poppins_medium" android:layout_marginRight="6dp" app:cornerRadius="20dp" app:strokeWidth="1dp" app:strokeColor="@color/divider"/>
                <Button android:id="@+id/btn_size_m" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="Size M" android:textColor="@color/text_primary" android:backgroundTint="@color/background_card" android:textAllCaps="false" android:fontFamily="@font/poppins_medium" android:layout_marginHorizontal="3dp" app:cornerRadius="20dp" app:strokeWidth="1dp" app:strokeColor="@color/divider"/>
                <Button android:id="@+id/btn_size_l" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="Size L" android:textColor="@color/text_primary" android:backgroundTint="@color/background_card" android:textAllCaps="false" android:fontFamily="@font/poppins_medium" android:layout_marginLeft="6dp" app:cornerRadius="20dp" app:strokeWidth="1dp" app:strokeColor="@color/divider"/>
            </LinearLayout>

            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Customize Per Finger (mm)"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="@font/poppins_bold"
                    android:layout_centerVertical="true"/>
                <TextView
                    android:id="@+id/btn_show_guide"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:text="Lihat Panduan ↗"
                    android:textColor="@color/lavender_dark"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_bold"
                    android:clickable="true"
                    android:focusable="true"/>
            </RelativeLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_card_rounded" android:padding="16dp" android:layout_marginBottom="24dp" android:elevation="2dp">
                <!-- 5 finger rows, sama seperti asli, hanya background card yang diganti -->
                <!-- Saya singkat agar tidak terlalu panjang, Anda dapat mempertahankan isi asli -->
                <RelativeLayout android:layout_width="match_parent" android:layout_height="48dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thumb (Ibu Jari)" android:textColor="@color/text_primary" android:fontFamily="@font/poppins_medium" android:layout_centerVertical="true"/>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_alignParentRight="true" android:gravity="center_vertical" android:orientation="horizontal">
                        <Button android:id="@+id/btn_minus_thumb" android:layout_width="32dp" android:layout_height="32dp" android:text="-" android:textSize="16sp" android:textColor="@color/lavender_dark" android:backgroundTint="@color/background_card" android:padding="0dp" app:cornerRadius="16dp" app:strokeWidth="1dp" app:strokeColor="@color/divider"/>
                        <TextView android:id="@+id/tv_val_thumb" android:layout_width="40dp" android:layout_height="wrap_content" android:text="14" android:textColor="@color/text_primary" android:textSize="16sp" android:fontFamily="@font/poppins_bold" android:gravity="center"/>
                        <Button android:id="@+id/btn_plus_thumb" android:layout_width="32dp" android:layout_height="32dp" android:text="+" android:textSize="16sp" android:textColor="@color/lavender_dark" android:backgroundTint="@color/background_card" android:padding="0dp" app:cornerRadius="16dp" app:strokeWidth="1dp" app:strokeColor="@color/divider"/>
                    </LinearLayout>
                </RelativeLayout>
                <!-- Ulangi untuk finger lainnya (index, middle, ring, pinky) dengan pola sama -->
            </LinearLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Special Custom Request Notes" android:textColor="@color/text_primary" android:textSize="15sp" android:fontFamily="@font/poppins_bold" android:layout_marginBottom="12dp"/>
            <EditText
                android:id="@+id/et_special_notes"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="@drawable/bg_card_rounded"
                android:gravity="top|left"
                android:padding="14dp"
                android:hint="Contoh: Tambahkan inisial huruf 'D' di kuku jari manis tangan kanan ya sis..."
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_medium"
                android:inputType="textMultiLine"
                android:scrollbars="vertical"
                android:layout_marginBottom="40dp"
                android:elevation="2dp"/>

        </LinearLayout>
    </ScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_next_details"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true"
        android:layout_margin="20dp"
        android:text="Next to Review"
        android:textColor="@color/white"
        android:backgroundTint="@color/lavender_dark"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:fontFamily="@font/poppins_bold"
        app:cornerRadius="28dp"
        android:elevation="4dp"/>

</RelativeLayout>