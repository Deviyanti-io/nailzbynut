<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <ScrollView
        android:id="@+id/layout_home_page"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_navigation"
        android:visibility="visible"
        android:scrollbars="none"
        android:padding="24dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tv_welcome_user"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hi, Cutie! 👋"
                        android:textColor="@color/text_primary"
                        android:textSize="26sp"
                        android:fontFamily="@font/fredoka_bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Let's find your perfect nail today ✨"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins_bold"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </RelativeLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginBottom="28dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/nail1"
                        android:scaleType="centerCrop"/>
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#33000000" />
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="24dp">
                        <TextView
                            android:id="@+id/tv_banner_tag"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NEW COLLECTION"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:fontFamily="@font/poppins_bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/tv_banner_tag"
                            android:text="Midnight Blue"
                            android:textColor="@color/white"
                            android:textSize="24sp"
                            android:fontFamily="@font/fredoka_bold"
                            android:layout_marginTop="4dp"/>
                        <androidx.appcompat.widget.AppCompatButton
                            android:layout_width="110dp"
                            android:layout_height="36dp"
                            android:layout_alignParentBottom="true"
                            android:backgroundTint="@color/lavender_dark"
                            android:fontFamily="@font/poppins_bold"
                            android:text="Shop Now"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            app:cornerRadius="18dp" />
                    </RelativeLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Our Services"
                android:textColor="@color/text_primary"
                android:textSize="19sp"
                android:fontFamily="@font/poppins_bold"
                android:layout_marginBottom="16dp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:alignmentMode="alignMargins"
                android:columnOrderPreserved="false"
                android:layout_marginBottom="28dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/menu_gel_nail"
                    android:layout_width="0dp"
                    android:layout_height="115dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/background_card">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">
                        <View
                            android:layout_width="40dp"
                            android:layout_height="50dp"
                            android:background="@drawable/ic_gel"
                            android:backgroundTint="@color/lavender_dark" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:fontFamily="@font/poppins_bold"
                            android:text="Gel Nail"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:gravity="center"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/menu_press_on_nail"
                    android:layout_width="0dp"
                    android:layout_height="115dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/background_card">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">
                        <View
                            android:layout_width="40dp"
                            android:layout_height="60dp"
                            android:background="@drawable/ic_layers"
                            android:backgroundTint="@color/lavender_dark" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="0dp"
                            android:fontFamily="@font/poppins_bold"
                            android:text="Press On"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:gravity="center"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/menu_manicure"
                    android:layout_width="0dp"
                    android:layout_height="115dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/background_card">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">
                        <View
                            android:layout_width="50dp"
                            android:layout_height="60dp"
                            android:background="@drawable/ic_nail_shape"
                            android:backgroundTint="@color/lavender_dark" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="0dp"
                            android:fontFamily="@font/poppins_bold"
                            android:text="Manicure"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:gravity="center"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </GridLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Best Sellers"
                android:textColor="@color/text_primary"
                android:textSize="19sp"
                android:fontFamily="@font/poppins_bold"
                android:layout_marginBottom="14dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="10dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="145dp"
                        android:layout_height="225dp"
                        android:layout_marginRight="16dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/background_card">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="145dp"
                                android:src="@drawable/nail2"
                                android:scaleType="centerCrop"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bluey Pink"
                                android:paddingLeft="14dp"
                                android:paddingTop="10dp"
                                android:textColor="@color/text_primary"
                                android:fontFamily="@font/poppins_bold"
                                android:textSize="14sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rp 85.000"
                                android:paddingLeft="14dp"
                                android:textColor="@color/lavender_dark"
                                android:fontFamily="@font/poppins_medium"
                                android:textSize="13sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="145dp"
                        android:layout_height="225dp"
                        android:layout_marginRight="16dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/background_card">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="145dp"
                                android:src="@drawable/nail3"
                                android:scaleType="centerCrop"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pink Aurora"
                                android:paddingLeft="14dp"
                                android:paddingTop="10dp"
                                android:textColor="@color/text_primary"
                                android:fontFamily="@font/poppins_bold"
                                android:textSize="14sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rp 85.000"
                                android:paddingLeft="14dp"
                                android:textColor="@color/lavender_dark"
                                android:fontFamily="@font/poppins_medium"
                                android:textSize="13sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="145dp"
                        android:layout_height="225dp"
                        android:layout_marginRight="16dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/background_card">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="145dp"
                                android:src="@drawable/nail9"
                                android:scaleType="centerCrop"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Marina Glaze"
                                android:paddingLeft="14dp"
                                android:paddingTop="10dp"
                                android:textColor="@color/text_primary"
                                android:fontFamily="@font/poppins_bold"
                                android:textSize="14sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rp 90.000"
                                android:paddingLeft="14dp"
                                android:textColor="@color/lavender_dark"
                                android:fontFamily="@font/poppins_medium"
                                android:textSize="13sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/layout_profile_page"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_navigation"
        android:visibility="gone"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">
        <View
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginTop="30dp"
            android:background="@drawable/ic_profile"
            android:backgroundTint="@color/lavender_medium" />
        <TextView
            android:id="@+id/tv_profile_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Name"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/poppins_bold" />
        <TextView
            android:id="@+id/tv_profile_email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="your.email@gmail.com"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_medium"
            android:layout_marginBottom="40dp" />
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_logout"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Logout Account"
            android:textColor="@color/white"
            android:backgroundTint="#FF5C5C"
            app:cornerRadius="25dp" />
    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_alignParentBottom="true"
        android:background="@color/background_card"
        app:itemIconTint="@color/lavender_dark"
        app:itemTextColor="@color/lavender_dark"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />

</RelativeLayout>