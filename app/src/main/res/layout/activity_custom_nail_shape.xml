<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Top bar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">
            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_back"
                app:tint="@color/text_primary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:fontFamily="@font/fredoka_bold"
                android:text="Custom Nail"
                android:textColor="@color/text_primary"
                android:textSize="20sp" />
        </RelativeLayout>

        <!-- Stepper progress -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="32dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_weight="1">
                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_circle_color"
                    android:backgroundTint="@color/lavender_dark"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="@color/white"
                    android:fontFamily="@font/poppins_bold"
                    android:textSize="13sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shape"
                    android:textColor="@color/lavender_dark"
                    android:textSize="11sp"
                    android:fontFamily="@font/poppins_bold"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>
            <View
                android:layout_width="35dp"
                android:layout_height="2dp"
                android:background="@color/divider"
                android:layout_marginHorizontal="6dp"
                android:layout_marginBottom="14dp"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_weight="1">
                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_circle_color"
                    android:backgroundTint="@color/divider"
                    android:gravity="center"
                    android:text="2"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="@font/poppins_bold"
                    android:textSize="13sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Color"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="@font/poppins_medium"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>
            <View
                android:layout_width="35dp"
                android:layout_height="2dp"
                android:background="@color/divider"
                android:layout_marginHorizontal="6dp"
                android:layout_marginBottom="14dp"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_weight="1">
                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_circle_color"
                    android:backgroundTint="@color/divider"
                    android:gravity="center"
                    android:text="3"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="@font/poppins_bold"
                    android:textSize="13sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Details"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="@font/poppins_medium"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>
            <View
                android:layout_width="35dp"
                android:layout_height="2dp"
                android:background="@color/divider"
                android:layout_marginHorizontal="6dp"
                android:layout_marginBottom="14dp"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_weight="1">
                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_circle_color"
                    android:backgroundTint="@color/divider"
                    android:gravity="center"
                    android:text="4"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="@font/poppins_bold"
                    android:textSize="13sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Review"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="@font/poppins_medium"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose Shape"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:fontFamily="@font/poppins_bold"
            android:layout_marginBottom="16dp"/>

        <!-- Row 1: Almond & Coffin -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">
            <LinearLayout
                android:id="@+id/btn_shape_almond"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_card_rounded"
                android:gravity="center"
                android:elevation="2dp"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical"
                android:padding="10dp">
                <ImageView android:layout_width="56dp" android:layout_height="56dp" android:src="@drawable/img_shape_almond" android:scaleType="fitCenter"/>
                <TextView android:id="@+id/tv_almond" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Almond" android:fontFamily="@font/poppins_medium" android:textColor="@color/text_primary" android:textSize="13sp"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/btn_shape_coffin"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_card_rounded"
                android:gravity="center"
                android:elevation="2dp"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical"
                android:padding="10dp">
                <ImageView android:layout_width="56dp" android:layout_height="56dp" android:src="@drawable/img_shape_coffin" android:scaleType="fitCenter"/>
                <TextView android:id="@+id/tv_coffin" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Coffin" android:fontFamily="@font/poppins_medium" android:textColor="@color/text_primary" android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Row 2: Square & Oval -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">
            <LinearLayout
                android:id="@+id/btn_shape_square"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_card_rounded"
                android:gravity="center"
                android:elevation="2dp"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical"
                android:padding="10dp">
                <ImageView android:layout_width="56dp" android:layout_height="56dp" android:src="@drawable/img_shape_square" android:scaleType="fitCenter"/>
                <TextView android:id="@+id/tv_square" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Square" android:fontFamily="@font/poppins_medium" android:textColor="@color/text_primary" android:textSize="13sp"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/btn_shape_oval"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_card_rounded"
                android:gravity="center"
                android:elevation="2dp"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical"
                android:padding="10dp">
                <ImageView android:layout_width="56dp" android:layout_height="56dp" android:src="@drawable/img_shape_oval" android:scaleType="fitCenter"/>
                <TextView android:id="@+id/tv_oval" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Oval" android:fontFamily="@font/poppins_medium" android:textColor="@color/text_primary" android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Row 3: Stiletto & Round -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">
            <LinearLayout
                android:id="@+id/btn_shape_stiletto"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_card_rounded"
                android:gravity="center"
                android:elevation="2dp"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical"
                android:padding="10dp">
                <ImageView android:layout_width="56dp" android:layout_height="56dp" android:src="@drawable/img_shape_stiletto" android:scaleType="fitCenter"/>
                <TextView android:id="@+id/tv_stiletto" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Stiletto" android:fontFamily="@font/poppins_medium" android:textColor="@color/text_primary" android:textSize="13sp"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/btn_shape_round"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_card_rounded"
                android:gravity="center"
                android:elevation="2dp"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical"
                android:padding="10dp">
                <ImageView android:layout_width="56dp" android:layout_height="56dp" android:src="@drawable/img_shape_round" android:scaleType="fitCenter"/>
                <TextView android:id="@+id/tv_round" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Round" android:fontFamily="@font/poppins_medium" android:textColor="@color/text_primary" android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Row 4: Squoval & Lipstick -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">
            <LinearLayout
                android:id="@+id/btn_shape_squoval"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_card_rounded"
                android:gravity="center"
                android:elevation="2dp"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical"
                android:padding="10dp">
                <ImageView android:layout_width="56dp" android:layout_height="56dp" android:src="@drawable/img_shape_squoval" android:scaleType="fitCenter"/>
                <TextView android:id="@+id/tv_squoval" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Squoval" android:fontFamily="@font/poppins_medium" android:textColor="@color/text_primary" android:textSize="13sp"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/btn_shape_lipstick"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_card_rounded"
                android:gravity="center"
                android:elevation="2dp"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical"
                android:padding="10dp">
                <ImageView android:layout_width="56dp" android:layout_height="56dp" android:src="@drawable/img_shape_lipstick" android:scaleType="fitCenter"/>
                <TextView android:id="@+id/tv_lipstick" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Lipstick" android:fontFamily="@font/poppins_medium" android:textColor="@color/text_primary" android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose Length"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:fontFamily="@font/poppins_bold"
            android:layout_marginBottom="16dp"/>
        
        <!-- untuk setiap pilihan panjang -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="40dp">
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_len_short"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Short"
                android:textAllCaps="false"
                android:fontFamily="@font/poppins_medium"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/background_card"
                app:cornerRadius="24dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider"/>
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_len_medium"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:text="Medium"
                android:textAllCaps="false"
                android:fontFamily="@font/poppins_medium"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/background_card"
                app:cornerRadius="24dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider"/>
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_len_long"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Long"
                android:textAllCaps="false"
                android:fontFamily="@font/poppins_medium"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/background_card"
                app:cornerRadius="24dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider"/>
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_next_step"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="@color/lavender_dark"
            android:text="Next Step"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:fontFamily="@font/poppins_bold"
            android:textSize="16sp"
            app:cornerRadius="28dp"
            android:elevation="4dp"/>
    </LinearLayout>
</ScrollView>