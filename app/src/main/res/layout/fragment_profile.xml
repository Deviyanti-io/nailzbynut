<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F9FF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginTop="20dp">

            <androidx.cardview.widget.CardView
                android:layout_width="100dp"
                android:layout_height="100dp"
                app:cardCornerRadius="50dp"
                app:cardElevation="0dp">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/nail1" /> </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nutty Nailz"
                android:textSize="22sp"
                android:textColor="#222222"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/fredoka_bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="nutty.nailz@gmail.com"
                android:textColor="#777777"
                android:fontFamily="@font/poppins_regular" />
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/gold_member">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvMemberStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gold Member"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:fontFamily="@font/poppins_bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.250 pts"
                    android:textColor="#FFFFFF"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/poppins_bold"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tvMemberStatus"
                    android:layout_marginTop="8dp"
                    android:text="Kamu punya 5 voucher gratis bulan ini! ✨"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="30dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="My Profile"
                android:gravity="center_vertical"
                android:drawableEnd="@android:drawable/ic_media_next"
                android:fontFamily="@font/poppins_medium"
                android:textColor="#222222" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <TextView
                android:id="@+id/menuBooking"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="My Bookings"
                android:gravity="center_vertical"
                android:drawableEnd="@android:drawable/ic_media_next"
                android:fontFamily="@font/poppins_medium"
                android:textColor="#222222" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Vouchers &amp; Promo"
                android:gravity="center_vertical"
                android:drawableEnd="@android:drawable/ic_media_next"
                android:fontFamily="@font/poppins_medium"
                android:textColor="#222222" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Settings"
                android:gravity="center_vertical"
                android:drawableEnd="@android:drawable/ic_media_next"
                android:fontFamily="@font/poppins_medium"
                android:textColor="#222222" />

        </LinearLayout>

        <Button
            android:id="@+id/btnSignOut"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="40dp"
            android:text="Sign Out"
            android:textColor="#FF5252"
            android:backgroundTint="#FFEBEB"
            android:fontFamily="@font/poppins_bold" />

    </LinearLayout>
</ScrollView>