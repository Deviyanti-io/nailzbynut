<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F9FF">

    <RelativeLayout
        android:id="@+id/layout_top_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp">
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_back"
            app:tint="#222222" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Booking Appointment"
            android:textSize="18sp"
            android:fontFamily="@font/fredoka_bold"
            android:textColor="#222222"
            android:layout_centerInParent="true" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layout_top_bar"
        android:layout_above="@+id/btnNextBooking"
        android:scrollbars="none"
        android:paddingHorizontal="20dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="24dp">
                <TextView android:layout_width="24dp" android:layout_height="24dp" android:text="✓" android:background="@drawable/bg_circle_color" android:backgroundTint="#7A75F0" android:textColor="#FFFFFF" android:gravity="center" android:fontFamily="@font/poppins_bold" android:textSize="12sp"/>
                <View android:layout_width="40dp" android:layout_height="2dp" android:background="#7A75F0"/>
                <TextView android:layout_width="24dp" android:layout_height="24dp" android:text="✓" android:background="@drawable/bg_circle_color" android:backgroundTint="#7A75F0" android:textColor="#FFFFFF" android:gravity="center" android:fontFamily="@font/poppins_bold" android:textSize="12sp"/>
                <View android:layout_width="40dp" android:layout_height="2dp" android:background="#7A75F0"/>
                <TextView android:layout_width="24dp" android:layout_height="24dp" android:text="✓" android:background="@drawable/bg_circle_color" android:backgroundTint="#7A75F0" android:textColor="#FFFFFF" android:gravity="center" android:fontFamily="@font/poppins_bold" android:textSize="12sp"/>
                <View android:layout_width="40dp" android:layout_height="2dp" android:background="#7A75F0"/>
                <TextView android:layout_width="24dp" android:layout_height="24dp" android:text="✓" android:background="@drawable/bg_circle_color" android:backgroundTint="#7A75F0" android:textColor="#FFFFFF" android:gravity="center" android:fontFamily="@font/poppins_bold" android:textSize="12sp"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pilih Tanggal"
                android:fontFamily="@font/poppins_bold"
                android:textColor="#222222"
                android:textSize="15sp"
                android:layout_marginBottom="12dp"/>

            <androidx.cardview.widget.CardView
                android:id="@+id/card_calendar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="#FFFFFF">
                <CalendarView
                    android:id="@+id/calendarView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:theme="@style/Theme.AppCompat.Light"/>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pilih Waktu"
                android:fontFamily="@font/poppins_bold"
                android:textColor="#222222"
                android:textSize="15sp"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <Button android:id="@+id/btnTime09" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="09.00" android:textColor="#222222" android:backgroundTint="#FFFFFF" android:textAllCaps="false" android:fontFamily="@font/poppins_medium" android:layout_marginEnd="8dp"/>
                <Button android:id="@+id/btnTime11" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="11.00" android:textColor="#222222" android:backgroundTint="#FFFFFF" android:textAllCaps="false" android:fontFamily="@font/poppins_medium" android:layout_marginEnd="8dp"/>
                <Button android:id="@+id/btnTime13" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="13.00" android:textColor="#222222" android:backgroundTint="#FFFFFF" android:textAllCaps="false" android:fontFamily="@font/poppins_medium"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="32dp">
                <Button android:id="@+id/btnTime14" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="14.00" android:textColor="#222222" android:backgroundTint="#FFFFFF" android:textAllCaps="false" android:fontFamily="@font/poppins_medium" android:layout_marginEnd="8dp"/>
                <Button android:id="@+id/btnTime15" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="15.00" android:textColor="#222222" android:backgroundTint="#FFFFFF" android:textAllCaps="false" android:fontFamily="@font/poppins_medium" android:layout_marginEnd="8dp"/>
                <Button android:id="@+id/btnTime17" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="17.00" android:textColor="#222222" android:backgroundTint="#FFFFFF" android:textAllCaps="false" android:fontFamily="@font/poppins_medium"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnNextBooking"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true"
        android:layout_margin="20dp"
        android:text="Confirm Booking"
        android:textColor="#FFFFFF"
        android:backgroundTint="#7A75F0"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:fontFamily="@font/poppins_bold"
        app:cornerRadius="16dp"
        android:elevation="2dp"/>

</RelativeLayout>