<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F9FF">

    <LinearLayout
        android:id="@+id/layout_fixed_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:background="#F9F9FF">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Explore"
                android:textColor="#1A1C29"
                android:textSize="24sp"
                android:fontFamily="@font/fredoka_bold"
                android:layout_centerVertical="true"/>
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentRight="true"
                android:src="@drawable/ic_cart"
                android:layout_centerVertical="true"
                app:tint="#1A1C29"/>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_card_menu"
            android:backgroundTint="#FFFFFF"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                app:tint="#8A8A93"/>
            <EditText
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="12dp"
                android:background="@null"
                android:hint="Search nail art, color, style..."
                android:textColorHint="#8A8A93"
                android:textColor="#1A1C29"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_medium"/>
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <androidx.appcompat.widget.AppCompatButton
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="All"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:fontFamily="@font/poppins_bold"
                    android:backgroundTint="#5A55CA"
                    android:layout_marginRight="8dp"
                    app:cornerRadius="12dp"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="Press On"
                    android:textColor="#5A55CA"
                    android:textAllCaps="false"
                    android:fontFamily="@font/poppins_bold"
                    android:backgroundTint="#EFEFFF"
                    android:layout_marginRight="8dp"
                    app:cornerRadius="12dp"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="Gel Nail"
                    android:textColor="#5A55CA"
                    android:textAllCaps="false"
                    android:fontFamily="@font/poppins_bold"
                    android:backgroundTint="#EFEFFF"
                    android:layout_marginRight="8dp"
                    app:cornerRadius="12dp"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="Custom"
                    android:textColor="#5A55CA"
                    android:textAllCaps="false"
                    android:fontFamily="@font/poppins_bold"
                    android:backgroundTint="#EFEFFF"
                    app:cornerRadius="12dp"/>
            </LinearLayout>
        </HorizontalScrollView>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toLeftOf="@+id/btn_filter_icon"
                android:scrollbars="none">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_card_menu"
                        android:backgroundTint="#FFFFFF"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:layout_marginRight="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Color"
                            android:textColor="#1A1C29"
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_medium"/>
                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_arrow_down"
                            android:layout_marginLeft="6dp"
                            app:tint="#1A1C29"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_card_menu"
                        android:backgroundTint="#FFFFFF"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:layout_marginRight="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Style"
                            android:textColor="#1A1C29"
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_medium"/>
                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_arrow_down"
                            android:layout_marginLeft="6dp"
                            app:tint="#1A1C29"/>
                    </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>
            <ImageView
                android:id="@id/btn_filter_icon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_filter"
                app:tint="#5A55CA"/>
        </RelativeLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layout_fixed_header"
        android:scrollbars="none"
        android:paddingHorizontal="10dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:alignmentMode="alignMargins"
            android:columnOrderPreserved="false">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="220dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <ImageView
                        android:id="@+id/img_n1"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:src="@drawable/nail1"
                        android:scaleType="centerCrop"/>
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentRight="true"
                        android:layout_margin="12dp"
                        android:src="@drawable/ic_heart_off"
                        app:tint="#FFFFFF"/>
                    <TextView
                        android:id="@+id/title_n1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/img_n1"
                        android:text="Dreamy Lavender"
                        android:paddingLeft="14dp"
                        android:paddingTop="10dp"
                        android:textColor="#1A1C29"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="13sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/title_n1"
                        android:text="Rp 95.000"
                        android:paddingLeft="14dp"
                        android:textColor="#8A8A93"
                        android:fontFamily="@font/poppins_medium"
                        android:textSize="12sp"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="220dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <ImageView
                        android:id="@+id/img_n2"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:src="@drawable/nail2"
                        android:scaleType="centerCrop"/>
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentRight="true"
                        android:layout_margin="12dp"
                        android:src="@drawable/ic_heart_off"
                        app:tint="#FFFFFF"/>
                    <TextView
                        android:id="@+id/title_n2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/img_n2"
                        android:text="Bluey Pink"
                        android:paddingLeft="14dp"
                        android:paddingTop="10dp"
                        android:textColor="#1A1C29"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="13sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/title_n2"
                        android:text="Rp 85.000"
                        android:paddingLeft="14dp"
                        android:textColor="#8A8A93"
                        android:fontFamily="@font/poppins_medium"
                        android:textSize="12sp"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="220dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <ImageView
                        android:id="@+id/img_n3"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:src="@drawable/nail3"
                        android:scaleType="centerCrop"/>
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentRight="true"
                        android:layout_margin="12dp"
                        android:src="@drawable/ic_heart_off"
                        app:tint="#FFFFFF"/>
                    <TextView
                        android:id="@+id/title_n3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/img_n3"
                        android:text="Pink Aurora"
                        android:paddingLeft="14dp"
                        android:paddingTop="10dp"
                        android:textColor="#1A1C29"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="13sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/title_n3"
                        android:text="Rp 85.000"
                        android:paddingLeft="14dp"
                        android:textColor="#8A8A93"
                        android:fontFamily="@font/poppins_medium"
                        android:textSize="12sp"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="220dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <ImageView
                        android:id="@+id/img_n4"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:src="@drawable/nail4"
                        android:scaleType="centerCrop"/>
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentRight="true"
                        android:layout_margin="12dp"
                        android:src="@drawable/ic_heart_off"
                        app:tint="#FFFFFF"/>
                    <TextView
                        android:id="@+id/title_n4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/img_n4"
                        android:text="Red Glossy"
                        android:paddingLeft="14dp"
                        android:paddingTop="10dp"
                        android:textColor="#1A1C29"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="13sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/title_n4"
                        android:text="Rp 80.000"
                        android:paddingLeft="14dp"
                        android:textColor="#8A8A93"
                        android:fontFamily="@font/poppins_medium"
                        android:textSize="12sp"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="220dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <ImageView
                        android:id="@+id/img_n5"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:src="@drawable/nail5"
                        android:scaleType="centerCrop"/>
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentRight="true"
                        android:layout_margin="12dp"
                        android:src="@drawable/ic_heart_off"
                        app:tint="#FFFFFF"/>
                    <TextView
                        android:id="@+id/title_n5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/img_n5"
                        android:text="Aurora Pearl"
                        android:paddingLeft="14dp"
                        android:paddingTop="10dp"
                        android:textColor="#1A1C29"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="13sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/title_n5"
                        android:text="Rp 85.000"
                        android:paddingLeft="14dp"
                        android:textColor="#8A8A93"
                        android:fontFamily="@font/poppins_medium"
                        android:textSize="12sp"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="220dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <ImageView
                        android:id="@+id/img_n10"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:src="@drawable/nail10"
                        android:scaleType="centerCrop"/>
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentRight="true"
                        android:layout_margin="12dp"
                        android:src="@drawable/ic_heart_off"
                        app:tint="#FFFFFF"/>
                    <TextView
                        android:id="@+id/title_n10"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/img_n10"
                        android:text="Sweet Lavender"
                        android:paddingLeft="14dp"
                        android:paddingTop="10dp"
                        android:textColor="#1A1C29"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="13sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/title_n10"
                        android:text="Rp 95.000"
                        android:paddingLeft="14dp"
                        android:textColor="#8A8A93"
                        android:fontFamily="@font/poppins_medium"
                        android:textSize="12sp"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="220dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <ImageView
                        android:id="@+id/img_n11"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:src="@drawable/nail11"
                        android:scaleType="centerCrop"/>
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentRight="true"
                        android:layout_margin="12dp"
                        android:src="@drawable/ic_heart_off"
                        app:tint="#FFFFFF"/>
                    <TextView
                        android:id="@+id/title_n11"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/img_n11"
                        android:text="Milky White"
                        android:paddingLeft="14dp"
                        android:paddingTop="10dp"
                        android:textColor="#1A1C29"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="13sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/title_n11"
                        android:text="Rp 75.000"
                        android:paddingLeft="14dp"
                        android:textColor="#8A8A93"
                        android:fontFamily="@font/poppins_medium"
                        android:textSize="12sp"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

        </GridLayout>
    </ScrollView>
</RelativeLayout>