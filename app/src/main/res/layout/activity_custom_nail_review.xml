<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F9FF">

    <RelativeLayout
        android:id="@+id/layout_top_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp">
        <ImageView
            android:id="@+id/btn_back_review"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_back"
            app:tint="#222222"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Custom Nail"
            android:textColor="#222222"
            android:textSize="18sp"
            android:fontFamily="@font/fredoka_bold"/>
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layout_top_bar"
        android:layout_above="@+id/btn_to_booking"
        android:scrollbars="none"
        android:paddingHorizontal="20dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="24dp">
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_weight="1">
                    <TextView android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_circle_color" android:backgroundTint="#7A75F0" android:text="✓" android:textColor="#FFFFFF" android:gravity="center" android:fontFamily="@font/poppins_bold" android:textSize="12sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Shape" android:textColor="#7A75F0" android:textSize="11sp" android:fontFamily="@font/poppins_medium" android:layout_marginTop="4dp"/>
                </LinearLayout>
                <View android:layout_width="35dp" android:layout_height="2dp" android:background="#7A75F0" android:layout_marginBottom="14dp"/>
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_weight="1">
                    <TextView android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_circle_color" android:backgroundTint="#7A75F0" android:text="✓" android:textColor="#FFFFFF" android:gravity="center" android:fontFamily="@font/poppins_bold" android:textSize="12sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Color" android:textColor="#7A75F0" android:textSize="11sp" android:fontFamily="@font/poppins_medium" android:layout_marginTop="4dp"/>
                </LinearLayout>
                <View android:layout_width="35dp" android:layout_height="2dp" android:background="#7A75F0" android:layout_marginBottom="14dp"/>
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_weight="1">
                    <TextView android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_circle_color" android:backgroundTint="#7A75F0" android:text="✓" android:textColor="#FFFFFF" android:gravity="center" android:fontFamily="@font/poppins_bold" android:textSize="12sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Details" android:textColor="#7A75F0" android:textSize="11sp" android:fontFamily="@font/poppins_medium" android:layout_marginTop="4dp"/>
                </LinearLayout>
                <View android:layout_width="35dp" android:layout_height="2dp" android:background="#7A75F0" android:layout_marginBottom="14dp"/>
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_weight="1">
                    <TextView android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_circle_color" android:backgroundTint="#7A75F0" android:text="4" android:textColor="#FFFFFF" android:gravity="center" android:fontFamily="@font/poppins_bold" android:textSize="12sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Review" android:textColor="#7A75F0" android:textSize="11sp" android:fontFamily="@font/poppins_bold" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Review Your Design" android:textColor="#222222" android:textSize="15sp" android:fontFamily="@font/poppins_bold" android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:id="@+id/layout_review_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_menu"
                android:padding="20dp"
                android:layout_marginBottom="24dp"
                android:elevation="1dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nail Shape" android:textColor="#8A8A93" android:textSize="12sp" android:fontFamily="@font/poppins_medium"/>
                <TextView android:id="@+id/tv_review_shape" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Almond" android:textColor="#222222" android:textSize="15sp" android:fontFamily="@font/poppins_bold" android:layout_marginBottom="14dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nail Length" android:textColor="#8A8A93" android:textSize="12sp" android:fontFamily="@font/poppins_medium"/>
                <TextView android:id="@+id/tv_review_length" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Medium" android:textColor="#222222" android:textSize="15sp" android:fontFamily="@font/poppins_bold" android:layout_marginBottom="14dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Color Type &amp; Hex" android:textColor="#8A8A93" android:textSize="12sp" android:fontFamily="@font/poppins_medium"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="14dp">
                    <View android:id="@+id/view_review_color_preview" android:layout_width="18dp" android:layout_height="18dp" android:background="@drawable/bg_circle_color" android:backgroundTint="#D6001C" android:layout_marginRight="8dp"/>
                    <TextView android:id="@+id/tv_review_color" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Solid (#D6001C)" android:textColor="#222222" android:textSize="15sp" android:fontFamily="@font/poppins_bold"/>
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Finishing Coat" android:textColor="#8A8A93" android:textSize="12sp" android:fontFamily="@font/poppins_medium"/>
                <TextView android:id="@+id/tv_review_finish" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Glossy" android:textColor="#222222" android:textSize="15sp" android:fontFamily="@font/poppins_bold" android:layout_marginBottom="14dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Selected Add-ons" android:textColor="#8A8A93" android:textSize="12sp" android:fontFamily="@font/poppins_medium"/>
                <TextView android:id="@+id/tv_review_addons" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Charms, Pearls" android:textColor="#222222" android:textSize="15sp" android:fontFamily="@font/poppins_bold" android:layout_marginBottom="14dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nail Size Specification" android:textColor="#8A8A93" android:textSize="12sp" android:fontFamily="@font/poppins_medium"/>
                <TextView android:id="@+id/tv_review_size" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Preset M (16-12-13-12-10mm)" android:textColor="#222222" android:textSize="15sp" android:fontFamily="@font/poppins_bold" android:layout_marginBottom="14dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Special Custom Request Notes" android:textColor="#8A8A93" android:textSize="12sp" android:fontFamily="@font/poppins_medium"/>
                <TextView android:id="@+id/tv_review_notes" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Tidak ada catatan tambahan." android:textColor="#222222" android:textSize="14sp" android:fontFamily="@font/poppins_medium"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_to_booking"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true"
        android:layout_margin="20dp"
        android:text="Proceed to Booking"
        android:textColor="#FFFFFF"
        android:backgroundTint="#7A75F0"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:fontFamily="@font/poppins_bold"
        app:cornerRadius="16dp"
        android:elevation="2dp"/>

</RelativeLayout>